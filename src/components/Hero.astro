---
---

<section class="hero">
  <!-- Ambient glow -->
  <div class="hero-glow"></div>

  <div class="container">
    <div class="hero-grid">
      <!-- Left: Content -->
      <div class="hero-content">
        <div class="hero-badge animate-fade-in">
          <span class="badge-dot"></span>
          <span>iOS & Android</span>
        </div>

        <h1 class="hero-title animate-fade-in-up delay-1">
          <span class="title-line">更好的</span>
          <span class="title-accent">V2EX</span>
          <span class="title-line">浏览体验</span>
        </h1>

        <p class="hero-desc animate-fade-in-up delay-2">
          专为 V2EX 社区设计的原生客户端。<br class="hidden-mobile" />
          简洁设计，流畅交互，让阅读成为享受。
        </p>

        <div class="hero-actions animate-fade-in-up delay-3">
          <a
            href="https://apps.apple.com/app/id1596137027"
            target="_blank"
            rel="noopener"
            class="btn-primary"
          >
            <i class="fab fa-apple"></i>
            App Store
          </a>

          <a
            href="https://play.google.com/store/apps/details?id=me.ghui.v2er"
            target="_blank"
            rel="noopener"
            class="btn-secondary"
          >
            <i class="fab fa-google-play"></i>
            Google Play
          </a>
        </div>

        <div class="hero-stats animate-fade-in-up delay-4">
          <div class="stat">
            <span class="stat-value">2017</span>
            <span class="stat-label">诞生年份</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">开源</span>
            <span class="stat-label">完全免费</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">原生</span>
            <span class="stat-label">极致性能</span>
          </div>
        </div>
      </div>

      <!-- Right: Simulated Phone -->
      <div class="hero-visual animate-fade-in delay-2">
        <div class="phone-wrapper">
          <!-- Floating Feature Cards -->
          <div class="floating-card floating-card-1">
            <i class="fas fa-bolt"></i>
            <span>原生性能</span>
          </div>

          <div class="floating-card floating-card-2">
            <i class="fas fa-moon"></i>
            <span>深色模式</span>
          </div>

          <div class="floating-card floating-card-3">
            <i class="fas fa-bell"></i>
            <span>即时通知</span>
          </div>

          <!-- Phone Frame -->
          <div class="phone-frame">
            <!-- Dynamic Island / Notch -->
            <div class="phone-notch"></div>

            <!-- Screen Content -->
            <div class="phone-screen">
              <!-- Status Bar -->
              <div class="status-bar">
                <span class="status-time">9:41</span>
                <div class="status-icons">
                  <i class="fas fa-signal"></i>
                  <i class="fas fa-wifi"></i>
                  <i class="fas fa-battery-full"></i>
                </div>
              </div>

              <!-- App Header -->
              <div class="app-header">
                <div class="app-title">首页</div>
                <div class="app-avatar">
                  <div class="avatar-circle"></div>
                </div>
              </div>

              <!-- Topic List -->
              <div class="topic-list">
                <!-- Topic 1 -->
                <div class="topic-item">
                  <div class="topic-node node-share">分享创造</div>
                  <div class="topic-title">开源了一个 V2EX 客户端，欢迎大家体验</div>
                  <div class="topic-meta">
                    <span class="topic-author">ghui</span>
                    <span class="topic-replies">128 回复</span>
                  </div>
                </div>

                <!-- Topic 2 -->
                <div class="topic-item">
                  <div class="topic-node node-tech">程序员</div>
                  <div class="topic-title">2024 年了，你们还在用什么技术栈？</div>
                  <div class="topic-meta">
                    <span class="topic-author">livid</span>
                    <span class="topic-replies">256 回复</span>
                  </div>
                </div>

                <!-- Topic 3 -->
                <div class="topic-item">
                  <div class="topic-node node-job">酷工作</div>
                  <div class="topic-title">远程工作机会：招聘前端工程师</div>
                  <div class="topic-meta">
                    <span class="topic-author">startup</span>
                    <span class="topic-replies">42 回复</span>
                  </div>
                </div>

                <!-- Topic 4 -->
                <div class="topic-item">
                  <div class="topic-node node-apple">Apple</div>
                  <div class="topic-title">新 MacBook Pro 使用体验分享</div>
                  <div class="topic-meta">
                    <span class="topic-author">macfan</span>
                    <span class="topic-replies">89 回复</span>
                  </div>
                </div>
              </div>

              <!-- Tab Bar -->
              <div class="tab-bar">
                <div class="tab-item tab-active">
                  <i class="fas fa-home"></i>
                </div>
                <div class="tab-item">
                  <i class="fas fa-th-large"></i>
                </div>
                <div class="tab-item">
                  <i class="fas fa-bell"></i>
                  <span class="tab-badge">3</span>
                </div>
                <div class="tab-item">
                  <i class="fas fa-user"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator animate-fade-in delay-5">
    <span>向下滚动</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    position: relative;
    padding: 5rem 0 3rem;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 60%;
    height: 80%;
    background: radial-gradient(
      ellipse at center,
      rgba(232, 168, 56, 0.08) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  /* Content */
  .hero-content {
    max-width: 600px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--amber-bg);
    border: 1px solid var(--amber-border);
    border-radius: 100px;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.05em;
    color: var(--amber);
    margin-bottom: var(--space-4);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--amber);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-4);
  }

  .title-line {
    display: block;
    color: var(--text-primary);
  }

  .title-accent {
    display: block;
    color: var(--amber);
    position: relative;
  }

  .hero-desc {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .hidden-mobile {
    display: none;
  }

  @media (min-width: 768px) {
    .hidden-mobile {
      display: inline;
    }
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .stat-label {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  .stat-divider {
    width: 1px;
    height: 2.5rem;
    background: var(--border-primary);
  }

  /* Visual / Phone Mockup */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .phone-wrapper {
    position: relative;
    width: 280px;
    height: 520px;
  }

  /* Floating Feature Cards */
  .floating-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: linear-gradient(
      135deg,
      var(--bg-card),
      var(--bg-secondary)
    );
    border: 1px solid var(--border-secondary);
    border-radius: 1rem;
    backdrop-filter: blur(10px);
    z-index: 10;
    animation: float 6s ease-in-out infinite;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .floating-card i {
    font-size: 1rem;
  }

  .floating-card span {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .floating-card-1 {
    left: -80px;
    top: 80px;
  }

  .floating-card-1 i {
    color: var(--amber);
  }

  .floating-card-2 {
    right: -70px;
    top: 200px;
    animation-delay: -2s;
  }

  .floating-card-2 i {
    color: #818cf8;
  }

  .floating-card-3 {
    left: -60px;
    bottom: 160px;
    animation-delay: -4s;
  }

  .floating-card-3 i {
    color: #34d399;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  /* Phone Frame */
  .phone-frame {
    position: relative;
    width: 240px;
    height: 480px;
    margin: 0 auto;
    padding: 10px;
    background: linear-gradient(135deg, #1a1a2e, #0f0f17);
    border: 2px solid #2a2a40;
    border-radius: 36px;
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.4),
      inset 0 0 20px rgba(0, 0, 0, 0.3);
  }

  .phone-notch {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 22px;
    background: #000;
    border-radius: 16px;
    z-index: 20;
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    background: var(--bg-primary);
    border-radius: 28px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Status Bar */
  .status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 18px 6px;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .status-time {
    font-family: var(--font-mono);
  }

  .status-icons {
    display: flex;
    gap: 5px;
    font-size: 0.625rem;
  }

  /* App Header */
  .app-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 12px 8px;
    border-bottom: 1px solid var(--border-primary);
  }

  .app-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .avatar-circle {
    width: 26px;
    height: 26px;
    background: linear-gradient(135deg, var(--amber), #f59e0b);
    border-radius: 50%;
  }

  /* Topic List */
  .topic-list {
    flex: 1;
    overflow: hidden;
    padding: 4px 0;
  }

  .topic-item {
    padding: 8px 12px;
    border-bottom: 1px solid var(--border-primary);
  }

  .topic-node {
    display: inline-block;
    padding: 1px 6px;
    font-size: 0.5625rem;
    font-weight: 600;
    border-radius: 3px;
    margin-bottom: 4px;
  }

  .node-share {
    background: rgba(232, 168, 56, 0.15);
    color: var(--amber);
  }

  .node-tech {
    background: rgba(99, 102, 241, 0.15);
    color: #818cf8;
  }

  .node-job {
    background: rgba(52, 211, 153, 0.15);
    color: #34d399;
  }

  .node-apple {
    background: rgba(244, 114, 182, 0.15);
    color: #f472b6;
  }

  .topic-title {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .topic-meta {
    display: flex;
    gap: 8px;
    font-size: 0.5625rem;
    color: var(--text-muted);
  }

  /* Tab Bar */
  .tab-bar {
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 8px 0;
    border-top: 1px solid var(--border-primary);
    background: var(--bg-secondary);
  }

  .tab-item {
    position: relative;
    padding: 6px 12px;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .tab-active {
    color: var(--amber);
  }

  .tab-badge {
    position: absolute;
    top: 0;
    right: 6px;
    min-width: 14px;
    height: 14px;
    padding: 0 3px;
    background: #ef4444;
    color: white;
    font-size: 0.5rem;
    font-weight: 700;
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Scroll indicator - hidden for compact layout */
  .scroll-indicator {
    display: none;
  }

  .scroll-line {
    display: none;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      text-align: center;
    }

    .hero-content {
      max-width: 100%;
      order: 1;
    }

    .hero-visual {
      order: 0;
    }

    .phone-wrapper {
      width: 220px;
      height: 420px;
    }

    .phone-frame {
      width: 200px;
      height: 400px;
      padding: 8px;
      border-radius: 32px;
    }

    .phone-notch {
      width: 80px;
      height: 24px;
    }

    .phone-screen {
      border-radius: 28px;
    }

    .floating-card {
      display: none;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-stats {
      justify-content: center;
    }

    .hero-badge {
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 4rem 0 2rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-desc {
      font-size: 0.9375rem;
    }

    .hero-stats {
      gap: var(--space-4);
    }

    .stat-value {
      font-size: 0.9375rem;
    }

    .phone-wrapper {
      width: 180px;
      height: 360px;
    }

    .phone-frame {
      width: 160px;
      height: 340px;
      padding: 6px;
      border-radius: 28px;
    }

    .phone-notch {
      width: 60px;
      height: 16px;
      top: 6px;
    }

    .phone-screen {
      border-radius: 22px;
    }

    .app-title {
      font-size: 1rem;
    }

    .topic-item {
      padding: 6px 10px;
    }

    .topic-title {
      font-size: 0.5625rem;
    }

    .topic-meta {
      font-size: 0.5rem;
    }
  }
</style>
