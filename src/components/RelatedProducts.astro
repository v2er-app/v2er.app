---
const products = [
  {
    name: '试试双拼',
    description: '投入一周时间，收获终身效率。这项简单实用的技能，值得你现在就开始学习。',
    url: 'https://ulpb.app',
    logo: '/image/shuangpin-logo.webp',
    color: '#6366f1'
  },
  {
    name: 'Daystill',
    description: '跟踪事件和特殊日子，你的最佳倒数日应用',
    url: 'https://daystill.app',
    logo: '/image/daystill-logo.webp',
    color: '#f59e0b'
  },
  {
    name: 'Pease',
    description: '美观简约的环境音混音器，为专注、放松或睡眠创造完美的声音环境',
    url: 'https://pease.day',
    logo: 'https://pease.day/icon-128x128.png',
    color: '#10b981'
  }
];
---

<section class="products" id="products">
  <div class="container">
    <div class="products-header">
      <div class="section-label">More Products</div>
      <h2 class="section-title">其他作品</h2>
      <p class="section-desc">
        来自同一开发者的其他应用，同样注重细节与体验
      </p>
    </div>

    <div class="products-grid">
      {products.map((product) => (
        <a
          href={product.url}
          target="_blank"
          rel="noopener"
          class="product-card"
          style={`--accent-color: ${product.color}`}
        >
          <div class="product-glow"></div>
          <div class="product-content">
            <div class="product-logo">
              <img src={product.logo} alt={`${product.name} Logo`} />
            </div>
            <div class="product-info">
              <h3 class="product-name">{product.name}</h3>
              <p class="product-desc">{product.description}</p>
            </div>
          </div>
          <div class="product-arrow">
            <i class="fas fa-arrow-right"></i>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .products {
    position: relative;
  }

  .products::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--border-primary) 20%,
      var(--border-primary) 80%,
      transparent
    );
  }

  .products-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-12);
  }

  .products-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 800px;
    margin: 0 auto;
  }

  .product-card {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-6);
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: 1rem;
    transition: all 0.4s var(--ease-out-expo);
    overflow: hidden;
  }

  .product-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-secondary);
    transform: translateX(8px);
  }

  .product-glow {
    position: absolute;
    top: 50%;
    left: -50%;
    width: 100%;
    height: 200%;
    background: radial-gradient(
      ellipse at center,
      var(--accent-color) 0%,
      transparent 70%
    );
    opacity: 0;
    transform: translateY(-50%);
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .product-card:hover .product-glow {
    opacity: 0.05;
  }

  .product-content {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    position: relative;
    z-index: 1;
  }

  .product-logo {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 0.875rem;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--bg-secondary);
  }

  .product-logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-info {
    flex: 1;
  }

  .product-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-1);
    transition: color 0.2s ease;
  }

  .product-card:hover .product-name {
    color: var(--amber);
  }

  .product-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 400px;
  }

  .product-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--bg-card-hover);
    border-radius: 50%;
    color: var(--text-tertiary);
    transition: all 0.3s var(--ease-out-quart);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .product-card:hover .product-arrow {
    background: var(--amber);
    color: #0a0a0a;
    transform: translateX(4px);
  }

  .product-arrow i {
    font-size: 0.75rem;
  }

  @media (max-width: 640px) {
    .product-card {
      padding: var(--space-5);
    }

    .product-content {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }

    .product-desc {
      max-width: none;
    }

    .product-arrow {
      position: absolute;
      top: var(--space-5);
      right: var(--space-5);
    }
  }
</style>
