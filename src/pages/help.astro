---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const platforms = [
  {
    name: 'Android',
    icon: 'fa-android',
    url: 'https://github.com/v2er-app/Android/issues/new',
    description: 'Android 版本的问题或建议',
    accentClass: 'platform-android'
  },
  {
    name: 'iOS',
    icon: 'fa-apple',
    url: 'https://github.com/v2er-app/iOS/issues/new',
    description: 'iOS 版本的问题或建议',
    accentClass: 'platform-ios'
  }
];

const tips = [
  '描述问题时请包含具体的操作步骤',
  '提供您的设备型号和系统版本',
  '如有可能，请附上截图或录屏',
  '提交前请先搜索是否已有相同问题'
];
---

<Layout title="问题反馈 - V2er">
  <Navbar />

  <main class="help-main">
    <div class="container">
      <div class="help-layout">
        <!-- Left: Header -->
        <div class="help-header">
          <div class="section-label">Feedback</div>
          <h1 class="section-title">问题反馈</h1>
          <p class="section-desc">
            GitHub Issues 是我们唯一的问题反馈渠道。请根据平台选择对应入口提交问题。
          </p>

          <!-- Warning -->
          <div class="help-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <span>请勿在 App Store 或 Google Play 评论区反馈问题，我们不会在商店中跟进。</span>
          </div>
        </div>

        <!-- Right: Content -->
        <div class="help-content">
          <!-- Platform Cards -->
          <div class="platform-cards">
            {platforms.map(platform => (
              <a
                href={platform.url}
                target="_blank"
                rel="noopener"
                class={`platform-card ${platform.accentClass}`}
              >
                <div class="platform-icon">
                  <i class={`fab ${platform.icon}`}></i>
                </div>
                <div class="platform-info">
                  <h2 class="platform-name">{platform.name}</h2>
                  <p class="platform-desc">{platform.description}</p>
                </div>
                <div class="platform-action">
                  <i class="fab fa-github"></i>
                  <span>提交 Issue</span>
                  <i class="fas fa-arrow-right platform-arrow"></i>
                </div>
              </a>
            ))}
          </div>

          <!-- Tips Section -->
          <div class="tips-section">
            <h3 class="tips-title">
              <i class="fas fa-lightbulb"></i>
              <span>提交高质量 Issue 的建议</span>
            </h3>
            <ul class="tips-list">
              {tips.map((tip, index) => (
                <li class="tip-item">
                  <span class="tip-index">{String(index + 1).padStart(2, '0')}</span>
                  <span class="tip-text">{tip}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .help-main {
    padding-top: 8rem;
    padding-bottom: var(--space-10);
    min-height: 100vh;
  }

  .help-layout {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (max-width: 900px) {
    .help-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  /* ── Header (Left) ── */

  .help-header {
    position: sticky;
    top: 8rem;
  }

  @media (max-width: 900px) {
    .help-header {
      position: static;
    }
  }

  .help-warning {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    margin-top: var(--space-8);
    padding: var(--space-4) var(--space-5);
    background: var(--amber-bg);
    border: 1px solid var(--amber-border);
    border-radius: 0.75rem;
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--amber);
  }

  .help-warning i {
    margin-top: 0.15rem;
    flex-shrink: 0;
  }

  /* ── Content (Right) ── */

  .help-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* ── Platform Cards ── */

  .platform-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .platform-card {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-6);
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: 1rem;
    transition: all 0.4s var(--ease-out-expo);
    cursor: pointer;
  }

  .platform-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-secondary);
    transform: translateY(-2px);
  }

  .platform-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    flex-shrink: 0;
    transition: all 0.3s var(--ease-out-quart);
  }

  .platform-icon i {
    font-size: 1.5rem;
  }

  /* Android accent */
  .platform-android .platform-icon {
    background: rgba(61, 220, 132, 0.1);
    color: #3DDC84;
  }

  .platform-android:hover .platform-icon {
    background: rgba(61, 220, 132, 0.18);
  }

  /* iOS accent */
  .platform-ios .platform-icon {
    background: var(--bg-card-hover);
    color: var(--text-primary);
  }

  .platform-ios:hover .platform-icon {
    background: var(--amber-bg);
    color: var(--amber);
  }

  .platform-info {
    flex: 1;
    min-width: 0;
  }

  .platform-name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }

  .platform-desc {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  .platform-action {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    white-space: nowrap;
    transition: all 0.3s var(--ease-out-quart);
    flex-shrink: 0;
  }

  .platform-card:hover .platform-action {
    border-color: var(--border-secondary);
    color: var(--text-primary);
  }

  .platform-arrow {
    font-size: 0.6875rem;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.3s var(--ease-out-quart);
  }

  .platform-card:hover .platform-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 640px) {
    .platform-card {
      flex-wrap: wrap;
      padding: var(--space-4) var(--space-5);
    }

    .platform-action {
      width: 100%;
      justify-content: center;
      margin-top: var(--space-2);
    }
  }

  /* ── Tips Section ── */

  .tips-section {
    border-top: 1px solid var(--border-primary);
    padding-top: var(--space-6);
  }

  .tips-title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-5);
  }

  .tips-title i {
    color: var(--amber);
    font-size: 0.875rem;
  }

  .tips-list {
    display: flex;
    flex-direction: column;
    list-style: none;
  }

  .tip-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-primary);
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .tip-item:last-child {
    border-bottom: none;
  }

  .tip-index {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    min-width: 1.5rem;
  }

  .tip-text {
    flex: 1;
    line-height: 1.6;
  }
</style>
